# 复制到 .env.local 并填写真实值
# 不要提交 .env.local 到 Git（已加入 .gitignore）

# ── AI 模型 API（必填）────────────────────────────────────
# 用于 Step1/2/4 AI 调用（支持 OpenAI 兼容格式）
# 如果同时有 OPENAI_API_KEY 和 ANTHROPIC_API_KEY，优先用 ANTHROPIC
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# 模型名，默认 gpt-4o-mini
AI_MODEL=gpt-4o-mini

# ── OpenAI Embedding API（RAG 必填）─────────────────────
# 用于 Step3 RAG 向量检索（text-embedding-3-small）
# ⚠️ 注意：RAG 知识库预处理和在线检索都需要此 Key
# 如果没有，Step3 会降级为 AI 语义匹配（效果稍差）
OPENAI_EMBEDDING_KEY=sk-your-openai-api-key-here

# ── Anthropic API（可选，优先于 OpenAI）──────────────────
# 如果配置了 ANTHROPIC_API_KEY，Step1/2/4 会优先使用 Claude
# ANTHROPIC_API_KEY=sk-ant-...

# ── IMA 知识库 API（可选，RAG 方案不需要）────────────
# IMA_CLIENT_ID=854077b593fb54bf8e1f141f200f1fd9
# IMA_API_KEY=I3O0DE9ntGHrRc5FHRM6MBHizLyQKQpDbf2p/Fm6wKTQ8l2EBc2uasAhvO1gzJwQHe68hxZ68g==
# IMA_BASE_URL=https://ima.qq.com

# ── Vercel 部署说明 ─────────────────────────────────────
# 在 Vercel Dashboard → Project → Settings → Environment Variables
# 添加以上变量（至少需要 OPENAI_API_KEY 或 ANTHROPIC_API_KEY）
# RAG 方案需要额外添加 OPENAI_EMBEDDING_KEY
# 不需要 .env.local，Vercel 会自动注入
